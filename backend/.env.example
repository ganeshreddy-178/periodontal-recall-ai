FLASK_ENV=development
FLASK_DEBUG=1
SECRET_KEY=change-this-super-secret-key-in-production
JWT_SECRET_KEY=change-this-jwt-secret-key-in-production

# MySQL
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password
DB_NAME=periodontal_recall_ai

# Upload
UPLOAD_FOLDER=uploads
MAX_CONTENT_LENGTH=16777216

# Model
MODEL_PATH=ai_module/models_saved/periodontal_cnn_model.h5

# Redis (optional for rate limiting / celery)
REDIS_URL=redis://localhost:6379/0
